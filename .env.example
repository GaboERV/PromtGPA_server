# ══════════════════════════════════════════════════════════════════════════════
# PromptGPT Server — Variables de Entorno
# ══════════════════════════════════════════════════════════════════════════════
# Copia este archivo como .env y configura los valores para tu entorno.
#   cp .env.example .env
# ══════════════════════════════════════════════════════════════════════════════

# ─── Base de Datos ───────────────────────────────────────────────────────────
# URI de conexión asíncrona. Ejemplos:
#   SQLite (desarrollo):    sqlite+aiosqlite:///./prompt_gpt.db
#   PostgreSQL (producción): postgresql+asyncpg://usuario:contraseña@host:5432/promptgpt
DATABASE_URL=sqlite+aiosqlite:///./prompt_gpt.db

# ─── Redis ───────────────────────────────────────────────────────────────────
# URI de Redis para caché, rate limiting, JTI de API Keys y audit logs.
# Si se deja vacío, el sistema usa diccionarios en memoria (solo desarrollo).
REDIS_URL=

# ─── Autenticación JWT ──────────────────────────────────────────────────────
# ⚠️  OBLIGATORIO CAMBIAR EN PRODUCCIÓN. Clave secreta para firmar tokens JWT.
JWT_SECRET_KEY=CAMBIAR-ESTA-CLAVE-EN-PRODUCCION
JWT_ALGORITHM=HS256

# ─── Seguridad: API Keys de Un Solo Uso ─────────────────────────────────────
# Cooldown en segundos entre generaciones de API Keys por usuario.
# Previene inyección masiva de recursos.
API_KEY_COOLDOWN_SECONDS=60

# ─── CORS (Cross-Origin Resource Sharing) ───────────────────────────────────
# Orígenes permitidos para peticiones con credenciales (cookies).
# Separar múltiples orígenes con coma. NO puede ser "*" cuando se usan cookies.
# Ejemplo producción: https://mi-frontend.com,https://www.mi-frontend.com
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ─── Testing ────────────────────────────────────────────────────────────────
# Activa NullPool en SQLAlchemy para evitar errores de event loop en tests.
# Solo activar al ejecutar test_flow.py.
IS_TESTING=false
