# ══════════════════════════════════════════════════════════════════════════════
# PromptGPT Server — Variables de Entorno
# ══════════════════════════════════════════════════════════════════════════════
# Este archivo es leído automáticamente por docker-compose.
# Copia este archivo como .env y ajusta los valores:
#
#   cp .env.example .env
#
# ══════════════════════════════════════════════════════════════════════════════

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=promptgpt
POSTGRES_PORT=5432

# ─── RAG ─────────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ─── Almacenamiento de Archivos ─────────────────────────────────────────────
STORAGE_BACKEND=local          # local | s3
STORAGE_LOCAL_PATH=./storage
MAX_FILE_SIZE_MB=50

# ─── LLM ─────────────────────────────────────────────────────────────────────
LLM_PROVIDER=gemini            # claude | openai | gemini | groq
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=sk...
GROQ_API_KEY=gsk_...

#──── Chroma ──────────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_data

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_PORT=6379

# ─── Servidor FastAPI ────────────────────────────────────────────────────────
APP_PORT=8000

# ─── Autenticación JWT ──────────────────────────────────────────────────────
# ⚠️  OBLIGATORIO CAMBIAR EN PRODUCCIÓN
JWT_SECRET_KEY=CAMBIAR-ESTA-CLAVE-EN-PRODUCCION
JWT_ALGORITHM=HS256

# ─── Seguridad: API Keys de Un Solo Uso ─────────────────────────────────────
# Cooldown en segundos entre generaciones de API Keys por usuario.
API_KEY_COOLDOWN_SECONDS=60

# ─── CORS ───────────────────────────────────────────────────────────────────
# Orígenes permitidos (separados por coma). NO puede ser "*" con cookies.
# Producción: https://mi-frontend.com,https://www.mi-frontend.com
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
